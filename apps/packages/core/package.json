{
  "name": "my-wispr-npm",
  "version": "0.3.0",
  "description": "Offline speech-to-text for Node.js — pipe any PCM stream into whisper.cpp. Same core for WebSocket SaaS, desktop apps, and VS Code extensions.",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./server": "./src/server.js"
  },
  "bin": {
    "my-wispr-setup": "scripts/setup.js"
  },
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "setup": "node scripts/setup.js",
    "test": "node -e \"import('./src/index.js').then(({ createWisprStream }) => console.log('OK — createWisprStream is', typeof createWisprStream)); import('./src/server.js').then(({ createWisprServer }) => console.log('OK — createWisprServer is', typeof createWisprServer));\""
  },
  "keywords": [
    "speech-to-text",
    "voice",
    "dictation",
    "whisper",
    "whisper.cpp",
    "offline",
    "transcription",
    "websocket",
    "streaming",
    "server-side",
    "desktop",
    "vscode",
    "saas",
    "real-time",
    "nodejs",
    "privacy"
  ],
  "author": "sainideep1234",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sainideep1234/my-wispr.git",
    "directory": "apps/packages/core"
  },
  "homepage": "https://github.com/sainideep1234/my-wispr#readme",
  "bugs": {
    "url": "https://github.com/sainideep1234/my-wispr/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "dependencies": {},
  "files": [
    "src/",
    "scripts/",
    "README.md",
    "LICENSE"
  ]
}
