{
  "name": "my-wispr-server",
  "version": "0.3.0",
  "description": "Demo hosts for my-wispr-npm — WebSocket SaaS server and local-mic desktop capture.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:desktop": "node desktop.js",
    "predev": "node scripts/setup.js",
    "dev": "node --watch --env-file=.env index.js",
    "dev:desktop": "node --watch --env-file=.env desktop.js"
  },
  "keywords": [
    "speech-to-text",
    "websocket",
    "transcription",
    "whisper",
    "server",
    "desktop"
  ],
  "author": "sainideep1234",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "my-wispr-npm": "file:../packages/core",
    "naudiodon2p": "^2.6.0",
    "ws": "^8.21.0"
  }
}
