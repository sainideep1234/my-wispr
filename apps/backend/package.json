{
  "name": "my-wispr-server",
  "version": "0.2.0",
  "description": "WebSocket transcription server for my-wispr — receives browser PCM audio, runs whisper.cpp server-side, streams text back.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "predev": "node scripts/setup.js",
    "dev": "node --watch --env-file=.env index.js"
  },
  "keywords": [
    "speech-to-text",
    "websocket",
    "transcription",
    "whisper",
    "server"
  ],
  "author": "sainideep1234",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "my-wispr-npm": "file:../packages/core",
    "naudiodon2p": "^2.6.0",
    "ws": "^8.21.0"
  }
}
