{
  "name": "my-wispr",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.4",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "apps/packages/*",
    "packages/*"
  ],
  "allowScripts": {
    "naudiodon2p@2.6.0": true,
    "segfault-handler@1.3.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
